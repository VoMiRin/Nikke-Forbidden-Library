{
  "name": "nikke-script-archive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:search-assets && vite",
    "build:search-assets": "tsc -p tsconfig.search-assets.json && node scripts/buildSearchAssets.mjs",
    "build": "npm run build:search-assets && vite build",
    "preview": "vite preview",
    "search-api": "node server/index.mjs",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "react-dom": "^19.1.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
